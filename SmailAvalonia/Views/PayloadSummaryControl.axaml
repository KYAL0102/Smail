<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:SmailAvalonia.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SmailAvalonia.Views.PayloadSummaryControl"
             x:DataType="vm:PayloadSummaryViewModel">
  <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Label Grid.Row="0" Grid.Column="0" 
          HorizontalAlignment="Center" FontWeight="Bold"
          Content="Summary"/>

    <Label Grid.Row="1" Grid.Column="0" Content="Subject:"/>
    <Border Grid.Row="2" Grid.Column="0" BorderBrush="White" BorderThickness="1" CornerRadius="5">
      <TextBlock Text="{Binding Subject}"
                 TextWrapping="Wrap"/>
    </Border>

    <Label Grid.Row="3" Grid.Column="0" Content="Message:"/>
    <Border Grid.Row="4" Grid.Column="0" BorderBrush="White" BorderThickness="1" CornerRadius="5">
      <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
        <TextBlock Text="{Binding Message}"
                    TextWrapping="Wrap" />
      </ScrollViewer>
    </Border>

    <Label Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" 
          Content="Primary channel" FontWeight="Bold" Margin="0,10,0,5"/>
    <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
            CornerRadius="10" 
            Padding="4" 
            HorizontalAlignment="Center">
        
        <ListBox ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannel}"
                Background="Transparent" 
                BorderThickness="0"
                SelectedIndex="0">
            
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.Styles>
                <Style Selector="ListBoxItem">
                    <Setter Property="Padding" Value="24,8"/>
                    <Setter Property="CornerRadius" Value="7"/>
                    <Setter Property="MinWidth" Value="100"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>

                <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                    <Setter Property="Background" Value="White"/>
                    <Setter Property="TextBlock.Foreground" Value="Black"/>
                    <Setter Property="BoxShadow" Value="0 1 3 0 rgba(27, 149, 176, 1)"/>
                </Style>
            </ListBox.Styles>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Border>

    <Label Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" 
       Content="Transmission Logic" FontWeight="Bold" Margin="0,10,0,5"/>
    <ItemsControl Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" 
                  ItemsSource="{Binding Strategies}"
                  HorizontalAlignment="Center">
        
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="20" HorizontalAlignment="Left"/>
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
            <DataTemplate>
                <RadioButton GroupName="SettingsGroup" 
                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            VerticalContentAlignment="Top" 
                            Width="200">
                    <StackPanel Margin="5,0,0,0">
                        <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding Description}" 
                                  FontSize="11" 
                                  Opacity="0.7" 
                                  TextWrapping="Wrap"/>
                    </StackPanel>
                </RadioButton>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>

    <Label Grid.Row="9" Grid.Column="0" Content="Recipients:"/>
    <Grid Grid.Row="10" Grid.Column="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Label Content="{Binding SmsContactsSentence}"/>
        <Label Content="SMS" VerticalAlignment="Center" HorizontalAlignment="Center"/>
      </StackPanel>

      <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
        <Label Content="{Binding EmailContactsSentence}"/>
        <Label Content="Email" VerticalAlignment="Center" HorizontalAlignment="Center"/>
      </StackPanel>
    </Grid>
    
    <UniformGrid Grid.Row="11" Grid.Column="0" Columns="2">
      <Button Content="Back" HorizontalAlignment="Left" Command="{Binding BackToConfigurationCommand}"/>
      <Button Content="Send" HorizontalAlignment="Right" Command="{Binding ExecutePayloadCommand}"/>
    </UniformGrid>
  </Grid>
</UserControl>
