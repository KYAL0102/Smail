<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SmailAvalonia.Views.DataSettingsControl"
             xmlns:vm="using:SmailAvalonia.ViewModels"
             x:DataType="vm:DataSettingsViewModel">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Label Grid.Row="0" Grid.Column="0" 
            Content="Basepath for Recipient-Pool" FontWeight="Bold"/>
      <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" 
                FontSize="11" 
                Opacity="0.7" 
                TextWrapping="Wrap"
                Text="{Binding RecipientpoolbasePathDescription}"/>
      <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
        <Button Content="Edit" Command="{Binding EditSourcePathCommand}"/>
        <Button Content="Cancel" Command="{Binding CancelSourcePathEditingCommand}"/>
        <Button Content="Apply" Command="{Binding ApplySourcePathCommand}"/>
      </StackPanel>
      <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DataSourcePathInput}" IsEnabled="{Binding EditingDataSource}">
        <TextBox.KeyBindings>
          <KeyBinding Command="{Binding ApplySourcePathCommand}" Gesture="Enter"/>
        </TextBox.KeyBindings>
      </TextBox>
      <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
            Foreground="Red" HorizontalAlignment="Right"
            Content="{Binding DataSrcErrorMsg}"/>

      <!--<TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                Text="This will delete the storage file, which contains Credentials, Tokens and Temporary Files"/>
      <Button Grid.Row="5" Grid.Column="0" Content="Clear data" Command="{Binding ClearStorageCommand}"/>

      <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                Text="This will delete all data and reset the application to the inital state of installation."/>
      <Button Grid.Row="7" Grid.Column="0" Content="Reset Application" Command="{Binding ResetApplicationCommand}"/>-->
    </Grid>
</UserControl>
