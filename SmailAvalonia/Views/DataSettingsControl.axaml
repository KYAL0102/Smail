<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="SmailAvalonia.Views.DataSettingsControl"
             xmlns:vm="using:SmailAvalonia.ViewModels"
             x:DataType="vm:DataSettingsViewModel">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                Text="If the source is set, the recipient table will use it as base - for every new payload, the newest state will be fetched from the source and stored locally so that it can be reused if the application is offline."/>
      <Button Grid.Row="1" Grid.Column="0" Content="Set source"/>
      <TextBox Grid.Row="1" Grid.Column="1"/>

      <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                Text="This will delete the storage file, which contains Credentials, Tokens and Temporary Files"/>
      <Button Grid.Row="3" Grid.Column="0" Content="Clear data"/>

      <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" TextWrapping="Wrap"
                Text="This will delete all data and reset the application to the inital state of installation."/>
      <Button Grid.Row="5" Grid.Column="0" Content="Reset Application"/>
    </Grid>
</UserControl>
